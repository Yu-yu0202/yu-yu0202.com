---
import { Image } from "astro:assets";
import { ArrowTopRightIcon } from "@radix-ui/react-icons";
import MainLayout from "@/layouts/MainLayout.astro";
---

<MainLayout title="Home">
  <div class="max-w-5xl space-y-8 py-8">
    <section>
      <h1 class="text-4xl leading-10 font-medium tracking-tight text-(--gray-12)">
        yu-yu0202 / ゆーゆー
      </h1>
      
      <p class="mt-3 text-sm tracking-wide text-(--gray-11)">
        Discord Bot / Software Developer
      </p>
      
      <p class="mt-6 max-w-2xl leading-relaxed text-(--gray-11)">
        Discord Bot やソフトウェア開発、競プロ等々広く浅くいろいろやってる暇人。
      </p>
    </section>

    <section>
      <h2 class="text-3xl font-medium text-(--gray-12) border-b border-(--gray-a4) pb-2">
        About Me
      </h2>
      
      <div class="mt-6">
        <h3 class="text-2xl font-medium text-(--gray-12) mb-2">Skills</h3>
        <ul class="list-disc list-inside text-(--gray-11) space-y-4 ml-1">
          <li>
            <span class="text-(--gray-12)">
              競技プログラミング
            </span>
            
            <div class="mt-1 pl-4 text-(--gray-11)">
              AtCoder Algorithm 茶 / Heuristic 水<br/>
              AJL 2025 Summer Algorithm 部門 7位 / Heuristic 部門 1位
            </div>
          </li>
          <li>
            <span class="text-(--gray-12)">
              プログラミング言語
            </span>

            <Image class="mt-2 pl-4" src="https://skillicons.dev/icons?i=ts,rust,cpp" alt="TypeScript, Rust, C++" height={400} width={150}/>
          </li>
          <li>
            <span class="text-(--gray-12)">
              フレームワーク
            </span>

            <Image class="mt-2 pl-4" src="https://skillicons.dev/icons?i=astro,nextjs,tauri" alt="Astro, Next.js, Tauri" height={400} width={150}/>
          </li>
          <li>
            <span class="text-(--gray-12)">
              インフラ
            </span>
            
            <Image class="mt-2 pl-4" src="https://skillicons.dev/icons?i=cloudflare,workers,postgresql,mysql,kubernetes" alt="Cloudflare, Cloudflare Workers, PostgreSQL, MySQL, Kubernetes" height={400} width={250}/>
            
            <div class="mt-2 text-(--gray-12)">
              ...and Proxmox
            </div>
          </li>
        </ul>
        
        <h3 class="mt-3 text-2xl font-medium text-(--gray-12) mb-2">Works</h3>
        <ul class="list-disc list-inside text-(--gray-11) space-y-4 ml-1">
          <li>
            <span class="mt-1 text-(--gray-12)">AviUtl2 の情報掲示板 Discord サーバー「AviUtl2の情報が知りたいだろって!!」 スタッフ</span>
            
            <div class="mt-1 pl-4 text-(--gray-11)">
              5000人規模のサーバーで、主に技術開発・モデレーター業務を担当しています。
            </div>
          </li>
          
          <li>
            <span class="mt-1 text-(--gray-12)">Discord Bot 「AviUtl Release Notify」 開発・運用</span>
            
            <div class="mt-1 pl-4 text-(--gray-11)">
              AviUtl2・AviUtl2 Plugin SDK のリリース情報を通知する Discord Bot を開発・運用しています。
            </div>
          </li>
          
          <li>
            <span class="mt-1 text-(--gray-12)">「AviUtl2 Style.conf Editor」 開発</span>
            
            <div class="mt-1 pl-4 text-(--gray-11)">
              AviUtl2 の style.conf を簡単に編集するためのソフトウェアを、Tauri と Next.js を用いて開発しています。
            </div>
          </li>
          
          <li>
            <span class="mt-1 text-(--gray-12)">Minecraft Plugin 「Deathswap Plugin」 開発</span>
            
            <div class="mt-1 pl-4 text-(--gray-11)">
              Minecraft 実況を行っている「Dream」さんの企画「Minecraft Death Swap」のようなミニゲームを Bukkit 向けに実装したプラグインを開発しています。
            </div>
          </li>
        </ul>
      </div>
    </section>
    
    <section>
      <h2 class="text-3xl font-medium text-(--gray-12) border-b border-(--gray-a4) pb-2">
        Links
      </h2>
      
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <a
          href="https://github.com/Yu-yu0202"
          target="_blank"
          rel="noopener noreferrer"
          class="link-card"
        >
          <div class="flex items-center justify-between">
            <span class="font-medium text-(--gray-12)">GitHub</span>
            <span class="link-card-arrow"><ArrowTopRightIcon /></span>
          </div>
          
          <p class="mt-1 text-sm text-(--gray-10)">
            @Yu-yu0202
          </p>
        </a>
        
        <a
          href="mailto:contact@yu-yu0202.com"
          class="link-card"
        >
          <div class="flex items-center justify-between">
            <span class="font-medium text-(--gray-12)">Email</span>
            <span class="link-card-arrow"><ArrowTopRightIcon /></span>
          </div>
          
          <p class="mt-1 text-sm text-(--gray-10)">
            contact@yu-yu0202.com
          </p>
        </a>
      </div>
    </section>
  </div>
  
  <style>
    .link-card {
      position: relative;
      display: block;
      
      padding: 1rem;
      
      border: 1px solid var(--gray-a5);
      border-radius: 0.75rem;
      
      background: var(--color-surface);
      
      text-decoration: none;
      
      transition:
        transform 250ms cubic-bezier(.16, 1, .3, 1),
        box-shadow 250ms cubic-bezier(.16, 1, .3, 1),
        border-color 150ms ease;
    }
    
    .link-card:hover {
      transform: translateY(-4px);
      
      border-color: var(--gray-a7);
      background: var(--gray-a2);
    }
    
    .link-card-arrow {
      color: var(--gray-10);
      
      transition:
        transform 250ms cubic-bezier(.16, 1, .3, 1),
        color 150ms ease;
    }
    
    .link-card:hover .link-card-arrow {
      color: var(--gray-12);
      transform: translate(4px, -4px);
    }
  </style>
</MainLayout>
