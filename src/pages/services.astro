---
import { Image } from "astro:assets";
import { Grid } from "@radix-ui/themes";
import aviutlReleaseNotifyIcon from "@/assets/images/service/aviutl-release-notify/icon.png";
import aviutl2StyleConfEditorIcon from "@/assets/images/service/aviutl2-style-conf-editor/icon.png";
import { ServiceCard } from "@/components/ServiceCard.tsx";
import MainLayout from "@/layouts/MainLayout.astro";
---

<MainLayout title="サービス一覧">
		<div class="max-w-5xl space-y-8 py-8">
				<h1 class="text-4xl font-medium text-(--gray-12) border-b border-(--gray-a4) pb-2">サービス一覧</h1>
				
				<Grid gap="3" columns="2">
            <ServiceCard
              href="/service/aviutl-release-notify"
              title="AviUtl Release Notify"
              description="AviUtl2・AviUtl2 Plugin SDK のリリースを通知する Discord Bot。"
            >
		            <Image src={aviutlReleaseNotifyIcon} alt="AviUtl Release Notify のアイコン" height="128" width="128" class="block" />
            </ServiceCard>
						
						<ServiceCard
							href="/service/aviutl2-style-conf-editor"
							title="AviUtl2 style.conf Editor"
							description="AviUtl2 の style.conf を編集するためのツール。"
						>
								<Image src={aviutl2StyleConfEditorIcon} alt="AviUtl2 style.conf Editor のアイコン" height="128" width="128" class="block" />
						</ServiceCard>
				</Grid>
		</div>

    <style is:global>
        .service-card {
            transition:
                transform 250ms cubic-bezier(.16, 1, .3, 1),
                box-shadow 250ms cubic-bezier(.16, 1, .3, 1),
                border-color 150ms ease,
                background-color 150ms ease;
        }

        .service-card:hover {
            transform: translateY(-4px);
            border-color: var(--gray-a7);
            background: var(--gray-a2);
        }

        .service-card-arrow {
            color: var(--gray-10);
            transition:
				        transform 250ms cubic-bezier(.16, 1, .3, 1),
                color 150ms ease;
        }

        .service-card:hover .service-card-arrow {
            color: var(--gray-12);
            transform: translate(4px, -4px);
        }
    </style>
</MainLayout>
