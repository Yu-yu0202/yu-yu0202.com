---
import { LogoutButton } from "@/components/LogoutButton";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={`${title} | Admin`}>
  <div class="grid grid-cols-[250px_1fr] grid-rows-[auto_1fr] h-screen gap-(--space-1) relative" style={{ position: "relative" }}>
    <header class="col-span-2 border-b border-(--gray-a6) flex items-center justify-between px-(--space-6) py-(--space-4) bg-(--color-surface) sticky top-0 z-10">
      <h1 class="text-2xl font-semibold m-0">管理画面</h1>
      <LogoutButton client:visible/>
    </header>

    <aside class="border-r border-(--gray-a6) bg-(--color-surface) overflow-y-auto">
      <nav class="flex flex-col py-(--space-4) px-0 gap-0">
        <a href="/admin/dashboard" class="flex items-center gap-(--space-2) px-(--space-4) py-(--space-2) text-(--font-size-2) no-underline transition-colors duration-200 cursor-pointer hover:bg-(--gray-a3)">
          📊 ダッシュボード
        </a>
        <a href="/admin/posts" class="flex items-center gap-(--space-2) px-(--space-4) py-(--space-2) text-(--gray-12) no-underline transition-colors duration-200 cursor-pointer hover:bg-(--gray-a3)">
          📝 ブログ記事
        </a>
        <a href="/admin/tags" class="flex items-center gap-(--space-2) px-(--space-4) py-(--space-2) text-(--font-size-2) no-underline transition-colors duration-200 cursor-pointer hover:bg-(--gray-a3)">
          🏷️ タグ管理
        </a>
      </nav>
    </aside>
    
    <main class="overflow-y-auto p-(--space-6)">
      <slot />
    </main>
  </div>

  <style>
    :global(.rt-BaseDialogOverlay) {
      position: fixed !important;
      inset: 0 !important;
      z-index: 9998 !important;
      background-color: rgba(0, 0, 0, 0.4) !important;
    }

    :global(.rt-BaseDialogScroll) {
      position: fixed !important;
      inset: 0 !important;
      z-index: 9999 !important;
    }
  </style>
</BaseLayout>
