---
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="flex flex-col h-screen overflow-y-auto">

    <header class="border-b border-(--gray-a6) flex items-center justify-between px-(--space-6) py-(--space-4) bg-(--color-surface)/80 backdrop-blur-md sticky top-0 z-10">
      <a href="/" class="text-3xl leading-10 font-medium m-0">ゆーゆー</a>
      
      <nav class="flex items-center gap-4 font-light text-base tracking-wide text-(--gray-12)">
        <a href="/blog" class="nav-link nav-link-blog inline-block relative py-1 text-(--gray-12) no-underline transition-colors">
          Blog
        </a>
        
        <span aria-hidden="true" class="inline-flex items-center px-1">
          <svg width="2" height="20" viewBox="0 0 2 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-(--gray-a8)">
            <rect x="0" y="0" width="2" height="20" rx="1" fill="currentColor" />
          </svg>
        </span>
        
        <a href="/services" class="nav-link nav-link-services inline-block relative py-1 text-(--gray-12) no-underline transition-colors">
          Services
        </a>
        
        <span aria-hidden="true" class="inline-flex items-center px-1">
          <svg width="2" height="20" viewBox="0 0 2 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-(--gray-a8)">
            <rect x="0" y="0" width="2" height="20" rx="1" fill="currentColor" />
          </svg>
        </span>
        
        <a href="/contact" class="nav-link nav-link-contact inline-block relative py-1 text-(--gray-12) no-underline transition-colors">
          Contact
        </a>
      </nav>
    </header>

    <main class="w-full max-w-7xl mx-auto px-(--space-6) py-3 flex-1 text-[18px] font-light">
      <slot/>
    </main>
    
    <footer class="mt-auto border-t border-(--gray-a4) py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-(--gray-11)">
        <div>
          &copy; 2026 ゆーゆーのお部屋 All rights reserved.
        </div>
        
        <nav class="flex items-center space-x-6">
          <a
            href="/contact"
            class="hover:underline hover:text-(--gray-12) transition-colors"
          >
            お問い合わせ
          </a>
          <a
            href="/privacy"
            class="hover:underline hover:text-(--gray-12) transition-colors"
          >
            プライバシーポリシー
          </a>
        </nav>
      </div>
    </footer>
    
    <style>
      .nav-link::after {
        content: "";
        
        position: absolute;
        left: 50%;
        bottom: 2px;
        
        width: 10px;
        height: 1px;
        
        background: currentColor;
        
        transform: translateX(-50%) scaleX(0);

        transition: transform 200ms ease-out;
      }
      
      .nav-link-blog:hover::after {
        transform: translateX(-50%) scaleX(4);
      }
      
      .nav-link-services:hover::after {
        transform: translateX(-50%) scaleX(7);
      }
      
      .nav-link-contact:hover::after {
        transform: translateX(-50%) scaleX(6);
      }
    </style>
  </div>
</BaseLayout>
