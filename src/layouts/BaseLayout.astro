---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { AppTheme } from "@/components/AppTheme";
import { Toaster } from "@/components/Toaster";

interface Props {
	title: string;
}

const { title } = Astro.props;

const umamiScriptUrl = import.meta.env.UMAMI_SCRIPT_URL;
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
---
<!DOCTYPE html>
<html lang="ja" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    {umamiScriptUrl && umamiWebsiteId && (
      <script
        is:inline
        defer
        src={umamiScriptUrl}
        data-website-id={umamiWebsiteId}
        data-performance="true"
        />
    )}

    <script is:inline>
      const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.classList.toggle('light', !isDark);
    </script>

    <style is:global>
      html, body {
        background-color: var(--color-background) !important;
        margin: 0;
        padding: 0;
        height: 100%;
      }
    </style>
  
    <Font cssVariable="--font-gen-interface-jp" preload={true} />
  </head>

  <body class="m-0 p-0 radix-themes font-sans font-medium antialiased">
    <Toaster client:idle />
    <div class="min-h-screen flex flex-col w-full m-0 p-0" id="app-root">
      <AppTheme
        hasBackground={true}
        className="flex-1 flex flex-col w-full"
      >
        <slot />
      </AppTheme>
    </div>
  </body>
</html>
